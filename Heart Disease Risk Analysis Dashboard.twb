        <zone flipboard-zone-id='5' h='14750' hidden='true' id='7' story-point-id='2' type-v2='text' w='75900' x='9400' y='80500'>
          <formatted-text>
            <run fontalignment='0'>This pie chart shows the overall distribution of individuals with and without heart disease. Most individuals in the dataset do not have heart disease, while a smaller percentage are affected.</run>
          </formatted-text>
        </zone>
        <zone flipboard-zone-id='5' forceUpdate='true' h='11625' id='8' story-point-id='1' type-v2='text' w='85600' x='9900' y='82750'>
          <formatted-text>
            <run fontalignment='0'>Heart disease cases tend to increase with age. Older age groups show a higher proportion of individuals affected by heart disease.</run>
          </formatted-text>
        </zone>
        <zone flipboard-zone-id='5' h='10500' hidden='true' id='9' story-point-id='3' type-v2='text' w='90400' x='4600' y='84000'>
          <formatted-text>
            <run fontalignment='0'>This heatmap shows the relationship between smoking and diabetes status. Lifestyle habits combined with medical conditions may influence health risks.</run>
          </formatted-text>
        </zone>
      </zones>
      <simple-id uuid='{E5C121F3-6D66-4549-AB60-2E356DCD357E}' />
