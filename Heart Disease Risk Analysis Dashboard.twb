              <flipboard active-id='1' nav-type='caption' show-nav-arrows='true'>
                <story-points>
                  <story-point caption='This project analyzes heart disease risk factors such as smoking habits, diabetes status, and age category using interactive visualizations. The goal is to identify patterns that may influence heart disease risk.' captured-sheet='Heart Disease Distribution by Age Group' id='1' />
                  <story-point caption='This project analyzes heart disease risk factors such as smoking habits, diabetes status, and age category using interactive visualizations. The goal is to identify patterns that may influence heart disease risk.' captured-sheet='Smoking vs Diabetes Distribution' id='3' />
                  <story-point caption='This project analyzes heart disease risk factors such as smoking habits, diabetes status, and age category using interactive visualizations. The goal is to identify patterns that may influence heart disease risk.' captured-sheet=' Heart Disease Pie Chart' id='2'>
                    <capturedDeltas>
                      <worksheet name=' Heart Disease Pie Chart'>
                        <selection-collection />
                      </worksheet>
                    </capturedDeltas>
                  </story-point>
                </story-points>
              </flipboard>
            </zone>
          </zone>
          <zone-style>
